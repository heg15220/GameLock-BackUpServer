TZ=Europe/Madrid

# Public site
DOMAIN=plataforma-juegos.example
SITE_URL=https://plataforma-juegos.example
LETSENCRYPT_EMAIL=admin@plataforma-juegos.example

# Shared Postgres database for production state.
POSTGRES_DB=plataforma_juegos
POSTGRES_USER=plataforma_juegos
POSTGRES_PASSWORD=change-me-with-a-long-random-password

# Wikipedia Gacha backend
WIKIPEDIA_GACHA_TOKEN_SECRET=change-me-with-a-long-random-secret
WIKIPEDIA_GACHA_WORKERS=2
WIKIPEDIA_GACHA_POSTGRES_POOL_MIN=2
WIKIPEDIA_GACHA_POSTGRES_POOL_MAX=8
WIKIPEDIA_GACHA_RATE_LIMIT_PER_MIN=60

# Node runtime guardrails for the lightweight game backends.
NODE_OPTIONS=--max-old-space-size=1024
