TZ=Europe/Madrid

# Public site
# DOMAIN is the apex host used as the certificate name / Let's Encrypt live dir.
# Nginx serves both the apex and the www subdomain (server_name ${DOMAIN} www.${DOMAIN}).
DOMAIN=game-lock.com
# SITE_URL is the canonical origin used for SEO (canonical, og:url, sitemap, robots).
SITE_URL=https://www.game-lock.com
LETSENCRYPT_EMAIL=admin@game-lock.com

# Nginx checks the shared certificate volume and reloads gracefully when
# Certbot installs a renewed certificate.
CERTIFICATE_RELOAD_INTERVAL_SECONDS=300

# Shared Postgres database for production state.
POSTGRES_DB=plataforma_juegos
POSTGRES_USER=plataforma_juegos
POSTGRES_PASSWORD=change-me-with-a-long-random-password

# Wikipedia Gacha backend
WIKIPEDIA_GACHA_TOKEN_SECRET=change-me-with-a-long-random-secret
WIKIPEDIA_GACHA_WORKERS=2
WIKIPEDIA_GACHA_POSTGRES_POOL_MIN=2
WIKIPEDIA_GACHA_POSTGRES_POOL_MAX=8
WIKIPEDIA_GACHA_RATE_LIMIT_PER_MIN=60

# Node runtime guardrails for the lightweight game backends.
NODE_OPTIONS=--max-old-space-size=1024
